<Window x:Class="CatchmentTool.UI.TinCatchmentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TIN-Based Catchment Delineation"
        Height="750" Width="620"
        MinHeight="650" MinWidth="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F0F0F0"
        Loaded="Window_Loaded">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="TIN-Based Catchment Delineation" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="Traces steepest descent on exact TIN surface — no rasterization" Foreground="Gray" FontSize="12"/>
        </StackPanel>

        <!-- Surface Selection -->
        <GroupBox Grid.Row="1" Header="1. Select TIN Surface" Margin="0,0,0,10">
            <ComboBox x:Name="cmbSurface" Height="25" Margin="5"/>
        </GroupBox>

        <!-- Inlet Structures Selection -->
        <GroupBox Grid.Row="2" Header="2. Select Inlet Structures" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="160"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                    <Button x:Name="btnSelectAll" Content="Select All" Width="80" Height="22"
                            Margin="0,0,5,0" Click="BtnSelectAll_Click"/>
                    <Button x:Name="btnSelectNone" Content="Select None" Width="80" Height="22"
                            Click="BtnSelectNone_Click"/>
                    <TextBlock x:Name="txtStructureCount" Margin="15,3,0,0"
                               Text="0 structures selected" Foreground="Gray"/>
                </StackPanel>
                <DataGrid x:Name="lstStructures" Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="1" BorderBrush="#CCCCCC"
                          RowBackground="White" AlternatingRowBackground="#F5F5F5"
                          FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="36" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Structure Name" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Part" Binding="{Binding PartFamilyName}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Network" Binding="{Binding NetworkName}" Width="*" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <!-- Settings -->
        <GroupBox Grid.Row="3" Header="3. Settings" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Grid Cell Size:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="txtCellSize" Grid.Row="0" Grid.Column="1" Text="1.0" Height="24" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="(ft or meters, depending on drawing units)" Foreground="Gray" FontSize="10" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Snap Tolerance:" VerticalAlignment="Center" Margin="0,8,10,0"/>
                <TextBox x:Name="txtSnapTolerance" Grid.Row="1" Grid.Column="1" Text="5.0" Height="24" VerticalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="(minimum distance to snap cells to inlets)" Foreground="Gray" FontSize="10" VerticalAlignment="Center" Margin="10,8,0,0"/>
            </Grid>
        </GroupBox>

        <!-- Progress Log -->
        <GroupBox Grid.Row="4" Header="Progress Log" Margin="0,0,0,10">
            <RichTextBox x:Name="rtbLog" IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="11"
                         Margin="5"
                         Background="#1E1E1E"
                         Foreground="#DCDCDC"
                         BorderThickness="0">
                <RichTextBox.Resources>
                    <Style TargetType="Paragraph">
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="LineHeight" Value="1"/>
                    </Style>
                </RichTextBox.Resources>
                <FlowDocument/>
            </RichTextBox>
        </GroupBox>

        <!-- Progress Bar -->
        <Grid Grid.Row="5" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0" x:Name="progressBar" Height="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Grid.Column="1" x:Name="txtStatus" Text="Ready" Foreground="Gray" VerticalAlignment="Center" MinWidth="150"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0">
            <Button x:Name="btnRun" Content="Run Delineation" Width="120" Height="32"
                    Click="BtnRun_Click" Margin="0,0,10,0"
                    Background="#0078D4" Foreground="White" FontWeight="SemiBold"/>
            <Button x:Name="btnClose" Content="Close" Width="80" Height="32"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
