<Window x:Class="CatchmentTool.UI.ImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Catchments" 
        Height="450" Width="500"
        MinHeight="400" MinWidth="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F0F0F0">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Import Catchment Polygons" 
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
        
        <!-- Catchments File -->
        <GroupBox Grid.Row="1" Header="1. Catchments File (JSON)" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtCatchmentsFile" Grid.Column="0" Height="23"/>
                <Button x:Name="btnBrowseFile" Grid.Column="1" Content="..." Width="30" 
                        Margin="5,0,0,0" Click="BtnBrowseFile_Click"/>
            </Grid>
        </GroupBox>
        
        <!-- Pipe Network Selection -->
        <GroupBox Grid.Row="2" Header="2. Select Pipe Network" Margin="0,0,0,10">
            <ComboBox x:Name="cmbNetwork" Height="25" Margin="5"/>
        </GroupBox>
        
        <!-- Surface Selection -->
        <GroupBox Grid.Row="3" Header="3. Select Surface" Margin="0,0,0,10">
            <ComboBox x:Name="cmbSurface" Height="25" Margin="5"/>
        </GroupBox>
        
        <!-- Log -->
        <GroupBox Grid.Row="4" Header="Log">
            <TextBox x:Name="txtLog" IsReadOnly="True" 
                     VerticalScrollBarVisibility="Visible"
                     FontFamily="Consolas" FontSize="11" 
                     Margin="5" TextWrapping="Wrap"
                     AcceptsReturn="True"/>
        </GroupBox>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnImport" Content="Import Catchments" Width="120" Height="30" 
                    Margin="0,0,10,0" Click="BtnImport_Click" IsDefault="True"/>
            <Button x:Name="btnClose" Content="Close" Width="80" Height="30" 
                    Click="BtnClose_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
