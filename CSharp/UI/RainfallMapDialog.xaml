<Window x:Class="CatchmentTool.UI.RainfallMapDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="TR-55 Rainfall Lookup — NOAA Atlas 14"
        Height="700" Width="900"
        MinHeight="550" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F0F0F0">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Select Site Location for P&#x2082; Rainfall" FontSize="16" FontWeight="Bold"/>
            <TextBlock Text="Click the map to place a pin. NOAA Atlas 14 will return the 2-year, 24-hour rainfall depth."
                       Foreground="Gray" FontSize="11" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Map -->
        <Border Grid.Row="1" BorderBrush="#999" BorderThickness="1" CornerRadius="3">
            <wv2:WebView2 x:Name="mapWebView" />
        </Border>

        <!-- Results Panel -->
        <Border Grid.Row="2" Margin="0,10,0,0" Padding="12" Background="White"
                BorderBrush="#CCC" BorderThickness="1" CornerRadius="3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Latitude -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Latitude" FontSize="10" Foreground="Gray"/>
                    <TextBlock x:Name="txtLatitude" Text="—" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>

                <Border Grid.Column="1" Width="1" Background="#DDD" Margin="5,0"/>

                <!-- Longitude -->
                <StackPanel Grid.Column="2" Margin="10,0,10,0">
                    <TextBlock Text="Longitude" FontSize="10" Foreground="Gray"/>
                    <TextBlock x:Name="txtLongitude" Text="—" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>

                <Border Grid.Column="3" Width="1" Background="#DDD" Margin="5,0"/>

                <!-- P2 Result -->
                <StackPanel Grid.Column="4" Margin="10,0,0,0">
                    <TextBlock Text="P&#x2082; (2-yr, 24-hr)" FontSize="10" Foreground="Gray"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="txtP2Value" Text="—" FontSize="20" FontWeight="Bold"
                                   Foreground="#0078D4"/>
                        <TextBlock x:Name="txtP2Unit" Text="" FontSize="12" Foreground="Gray"
                                   VerticalAlignment="Bottom" Margin="4,0,0,2"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Manual override -->
            <TextBlock Grid.Column="0" Text="Manual P&#x2082; override:"
                       VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"/>
            <TextBox x:Name="txtManualP2" Grid.Column="1" Width="70" Height="28"
                     VerticalContentAlignment="Center" FontSize="12"
                     TextChanged="TxtManualP2_TextChanged"/>

            <!-- Status -->
            <TextBlock x:Name="txtStatus" Grid.Column="2"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Foreground="Gray" FontSize="11"/>

            <!-- OK / Cancel -->
            <Button x:Name="btnOk" Grid.Column="3" Content="Use This P&#x2082;" Width="120" Height="32"
                    Margin="0,0,8,0" Click="BtnOk_Click" IsDefault="True" IsEnabled="False"
                    FontWeight="SemiBold" Background="#0078D4" Foreground="White"/>
            <Button Grid.Column="4" Content="Cancel" Width="80" Height="32"
                    Click="BtnCancel_Click" IsCancel="True"/>
        </Grid>
    </Grid>
</Window>
