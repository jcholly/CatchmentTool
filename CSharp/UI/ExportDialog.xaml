<Window x:Class="CatchmentTool.UI.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Catchment Data" 
        Height="550" Width="550"
        MinHeight="500" MinWidth="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F0F0F0">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Export Surface &amp; Inlet Data" 
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
        
        <!-- Surface Selection -->
        <GroupBox Grid.Row="1" Header="1. Select Surface" Margin="0,0,0,10">
            <ComboBox x:Name="cmbSurface" Height="25" Margin="5"/>
        </GroupBox>
        
        <!-- Pipe Network Selection -->
        <GroupBox Grid.Row="2" Header="2. Select Pipe Network" Margin="0,0,0,10">
            <ComboBox x:Name="cmbNetwork" Height="25" Margin="5" SelectionChanged="CmbNetwork_SelectionChanged"/>
        </GroupBox>
        
        <!-- Structure Types Selection -->
        <GroupBox Grid.Row="3" Header="3. Select Structure Types to Include as Inlets" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="120"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                    <Button x:Name="btnSelectAll" Content="Select All" Width="80" Height="22" 
                            Margin="0,0,5,0" Click="BtnSelectAll_Click"/>
                    <Button x:Name="btnSelectNone" Content="Select None" Width="80" Height="22" 
                            Click="BtnSelectNone_Click"/>
                    <TextBlock x:Name="txtStructureCount" Margin="15,3,0,0" 
                               Text="0 structures selected" Foreground="Gray"/>
                </StackPanel>
                <ListBox x:Name="lstStructureTypes" Grid.Row="1" 
                         SelectionMode="Multiple"
                         BorderThickness="1" BorderBrush="#CCCCCC">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding DisplayName}" 
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Margin="2" Click="StructureType_CheckChanged"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </GroupBox>
        
        <!-- Working Directory -->
        <GroupBox Grid.Row="4" Header="4. Working Directory" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtWorkingDir" Grid.Column="0" Height="23"/>
                <Button x:Name="btnBrowse" Grid.Column="1" Content="..." Width="30" 
                        Margin="5,0,0,0" Click="BtnBrowse_Click"/>
            </Grid>
        </GroupBox>
        
        <!-- Log -->
        <GroupBox Grid.Row="5" Header="Log">
            <TextBox x:Name="txtLog" IsReadOnly="True" 
                     VerticalScrollBarVisibility="Visible"
                     FontFamily="Consolas" FontSize="11" 
                     Margin="5" TextWrapping="Wrap"
                     AcceptsReturn="True"/>
        </GroupBox>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnExport" Content="Export Data" Width="100" Height="30" 
                    Margin="0,0,10,0" Click="BtnExport_Click" IsDefault="True"/>
            <Button x:Name="btnClose" Content="Close" Width="80" Height="30" 
                    Click="BtnClose_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
