<Window x:Class="CatchmentTool.UI.CatchmentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Catchment Delineation Tool" 
        Height="650" Width="550"
        MinHeight="500" MinWidth="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F0F0F0">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Automated Catchment Delineation" 
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
        
        <!-- Surface Selection -->
        <GroupBox Grid.Row="1" Header="1. Select Surface" Margin="0,0,0,10">
            <ComboBox x:Name="cmbSurface" Height="25" Margin="5"/>
        </GroupBox>
        
        <!-- Pipe Network Selection -->
        <GroupBox Grid.Row="2" Header="2. Select Pipe Network" Margin="0,0,0,10">
            <ComboBox x:Name="cmbNetwork" Height="25" Margin="5"/>
        </GroupBox>
        
        <!-- Options -->
        <GroupBox Grid.Row="3" Header="3. Options" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Working Directory:" 
                           VerticalAlignment="Center" Margin="0,0,10,5"/>
                <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtWorkingDir" Grid.Column="0" Height="23"/>
                    <Button x:Name="btnBrowse" Grid.Column="1" Content="..." Width="30" 
                            Margin="5,0,0,0" Click="BtnBrowse_Click"/>
                </Grid>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Snap Distance:" 
                           VerticalAlignment="Center" Margin="0,0,10,5"/>
                <TextBox x:Name="txtSnapDistance" Grid.Row="1" Grid.Column="1" 
                         Text="10.0" Height="23" Width="80" HorizontalAlignment="Left" Margin="0,0,0,5"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Python Path:" 
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="txtPythonPath" Grid.Row="2" Grid.Column="1" 
                         Text="python" Height="23"/>
            </Grid>
        </GroupBox>
        
        <!-- Progress -->
        <GroupBox Grid.Row="4" Header="4. Progress" Margin="0,0,0,10">
            <StackPanel Margin="5">
                <ProgressBar x:Name="progressBar" Height="20" Margin="0,0,0,5"/>
                <TextBlock x:Name="txtStatus" Text="Ready" TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>
        
        <!-- Log -->
        <GroupBox Grid.Row="5" Header="Log" MinHeight="150">
            <TextBox x:Name="txtLog" IsReadOnly="True" 
                     VerticalScrollBarVisibility="Visible"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="11" 
                     Margin="5" TextWrapping="NoWrap"
                     AcceptsReturn="True"/>
        </GroupBox>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnRun" Content="Run Delineation" Width="120" Height="30" 
                    Margin="0,0,10,0" Click="BtnRun_Click" IsDefault="True"/>
            <Button x:Name="btnCancel" Content="Close" Width="80" Height="30" 
                    Click="BtnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
