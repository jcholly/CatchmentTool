<Window x:Class="CatchmentTool.UI.AutoCatchmentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Automated Catchment Delineation" 
        Height="720" Width="620"
        MinHeight="650" MinWidth="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F0F0F0">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Automated Catchment Delineation" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="One-step: Export → Analyze → Import" Foreground="Gray" FontSize="12"/>
        </StackPanel>
        
        <!-- Surface Selection -->
        <GroupBox Grid.Row="1" Header="1. Select Surface" Margin="0,0,0,10">
            <ComboBox x:Name="cmbSurface" Height="25" Margin="5"/>
        </GroupBox>
        
        <!-- Pipe Network Selection -->
        <GroupBox Grid.Row="2" Header="2. Select Pipe Network" Margin="0,0,0,10">
            <ComboBox x:Name="cmbNetwork" Height="25" Margin="5" SelectionChanged="CmbNetwork_SelectionChanged"/>
        </GroupBox>
        
        <!-- Structure Types Selection -->
        <GroupBox Grid.Row="3" Header="3. Select Structure Types to Include as Inlets" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="100"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                    <Button x:Name="btnSelectAll" Content="Select All" Width="80" Height="22" 
                            Margin="0,0,5,0" Click="BtnSelectAll_Click"/>
                    <Button x:Name="btnSelectNone" Content="Select None" Width="80" Height="22" 
                            Click="BtnSelectNone_Click"/>
                    <TextBlock x:Name="txtStructureCount" Margin="15,3,0,0" 
                               Text="0 structures selected" Foreground="Gray"/>
                </StackPanel>
                <ListBox x:Name="lstStructureTypes" Grid.Row="1" 
                         SelectionMode="Multiple"
                         BorderThickness="1" BorderBrush="#CCCCCC">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding DisplayName}" 
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Margin="2" Click="StructureType_CheckChanged"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </GroupBox>
        
        <!-- Analysis Settings -->
        <Expander Grid.Row="4" Header="4. Analysis Settings (Advanced)" Margin="0,0,0,10" IsExpanded="False">
            <Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="10" Background="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- DEM Cell Size -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,8">
                        <TextBlock x:Name="lblCellSize" Text="DEM Cell Size:" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cmbCellSize" Height="24" Margin="0,3,0,0">
                            <!-- Items populated by code-behind based on drawing units -->
                        </ComboBox>
                    </StackPanel>

                    <!-- Snap Distance -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,8">
                        <TextBlock x:Name="lblSnapDistance" Text="Snap Distance:" FontWeight="SemiBold"/>
                        <TextBlock Text="Distance to snap inlets to flow path" FontSize="10" Foreground="Gray"/>
                        <TextBox x:Name="txtSnapDistance" Text="10" Height="24" Margin="0,3,0,0"/>
                    </StackPanel>

                    <!-- Breach Distance -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,8">
                        <TextBlock Text="Breach Distance (cells):" FontWeight="SemiBold"/>
                        <TextBlock Text="Max distance to breach depressions" FontSize="10" Foreground="Gray"/>
                        <TextBox x:Name="txtBreachDistance" Text="10" Height="24" Margin="0,3,0,0"/>
                    </StackPanel>

                    <!-- Depression Method -->
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,8">
                        <TextBlock Text="Depression Handling:" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cmbDepressionMethod" Height="24" Margin="0,3,0,0">
                            <ComboBoxItem Content="Breach (recommended)" Tag="breach" IsSelected="True"/>
                            <ComboBoxItem Content="Fill" Tag="fill"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Min Catchment Area -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,8">
                        <TextBlock x:Name="lblMinArea" Text="Min Catchment Area:" FontWeight="SemiBold"/>
                        <TextBlock Text="Filter out tiny catchments" FontSize="10" Foreground="Gray"/>
                        <TextBox x:Name="txtMinArea" Text="100" Height="24" Margin="0,3,0,0"/>
                    </StackPanel>

                    <!-- Simplify Tolerance -->
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,8">
                        <TextBlock x:Name="lblSimplifyTolerance" Text="Simplify Tolerance:" FontWeight="SemiBold"/>
                        <TextBlock Text="0 = no simplification" FontSize="10" Foreground="Gray"/>
                        <TextBox x:Name="txtSimplifyTolerance" Text="1" Height="24" Margin="0,3,0,0"/>
                    </StackPanel>

                    <!-- Burn Pipes -->
                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,10,0">
                        <CheckBox x:Name="chkBurnPipes" Content="Burn pipes into DEM"
                                  IsChecked="True" FontWeight="SemiBold"/>
                        <TextBlock Text="Lowers DEM along pipe paths" FontSize="10" Foreground="Gray" Margin="20,0,0,0"/>
                    </StackPanel>

                    <!-- Burn Depth -->
                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock x:Name="lblBurnDepth" Text="Burn Depth:" FontWeight="SemiBold"/>
                        <TextBlock Text="How deep to lower pipe cells" FontSize="10" Foreground="Gray"/>
                        <TextBox x:Name="txtBurnDepth" Text="3" Height="24" Margin="0,3,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Expander>
        
        <!-- Progress Log -->
        <GroupBox Grid.Row="5" Header="Progress Log">
            <TextBox x:Name="txtLog" IsReadOnly="True" 
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="11" 
                     Margin="5" TextWrapping="NoWrap"
                     AcceptsReturn="True" Background="#1E1E1E" Foreground="#DCDCDC"/>
        </GroupBox>
        
        <!-- Progress Bar -->
        <Grid Grid.Row="6" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="progressBar" Grid.Column="0" Height="20" Minimum="0" Maximum="100"/>
            <TextBlock x:Name="txtProgress" Grid.Column="1" Margin="10,0,0,0" 
                       VerticalAlignment="Center" Text="Ready"/>
        </Grid>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnRun" Content="Run Delineation" Width="120" Height="32" 
                    Margin="0,0,10,0" Click="BtnRun_Click" IsDefault="True"
                    FontWeight="SemiBold" Background="#0078D4" Foreground="White"/>
            <Button x:Name="btnClose" Content="Close" Width="80" Height="32" 
                    Click="BtnClose_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
