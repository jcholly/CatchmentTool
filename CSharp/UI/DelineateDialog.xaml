<Window x:Class="CatchmentTool.UI.DelineateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Catchment Delineation"
        Height="640" Width="600"
        MinHeight="540" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F0F0F0"
        Loaded="Window_Loaded">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Catchment Delineation" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="Tuned algorithm — pick pour-point inlets and run. No settings needed." Foreground="Gray" FontSize="12"/>
        </StackPanel>

        <!-- Surface Selection -->
        <GroupBox Grid.Row="1" Header="1. Select TIN Surface" Margin="0,0,0,10">
            <ComboBox x:Name="cmbSurface" Height="25" Margin="5"/>
        </GroupBox>

        <!-- Pipe Network Selection -->
        <GroupBox Grid.Row="2" Header="2. Select Pipe Network" Margin="0,0,0,10">
            <ComboBox x:Name="cmbNetwork" Height="25" Margin="5"/>
        </GroupBox>

        <!-- Pour-point structure selection -->
        <GroupBox Grid.Row="3" Header="3. Pour-point Inlets / Outfalls (one catchment per checked structure)" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="220"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                    <Button x:Name="btnSelectAll" Content="Select All" Width="80" Height="22"
                            Margin="0,0,5,0" Click="BtnSelectAll_Click"/>
                    <Button x:Name="btnSelectNone" Content="Select None" Width="80" Height="22"
                            Margin="0,0,5,0" Click="BtnSelectNone_Click"/>
                    <Button x:Name="btnSelectPonds" Content="Ponds Only"  Width="80" Height="22"
                            Click="BtnSelectPonds_Click" ToolTip="Select only structures with no downstream pipe (terminal sumps)."/>
                    <TextBlock x:Name="txtStructureCount" Margin="15,3,0,0"
                               Text="0 structures selected" Foreground="Gray"/>
                </StackPanel>
                <DataGrid x:Name="lstStructures" Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="1" BorderBrush="#CCCCCC"
                          RowBackground="White" AlternatingRowBackground="#F5F5F5"
                          FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="36" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Structure" Binding="{Binding Name}" Width="*"  IsReadOnly="True"/>
                        <DataGridTextColumn Header="Kind"      Binding="{Binding Kind}" Width="80" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Rim"       Binding="{Binding RimDisplay}" Width="80" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <!-- Log -->
        <RichTextBox x:Name="txtLog" Grid.Row="4" Margin="0,0,0,10"
                     Background="#1E1E1E" Foreground="White"
                     FontFamily="Consolas" FontSize="11"
                     IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>

        <!-- Status -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock x:Name="txtStatus" Text="Ready." VerticalAlignment="Center" Margin="0,0,15,0"/>
            <ProgressBar x:Name="progress" Width="200" Height="14" Visibility="Collapsed"/>
        </StackPanel>

        <!-- Actions -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnRun"   Content="Run Delineation" Width="140" Height="28" Margin="0,0,8,0" Click="BtnRun_Click" IsDefault="True"/>
            <Button x:Name="btnClose" Content="Close"           Width="80"  Height="28" Click="BtnClose_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
